// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if request user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if request user has 'admin' role in their user doc
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if request user is the owner of a document by studentId field
    function isOwner(studentId) {
      return isAuth() && request.auth.uid == studentId;
    }

    // ---------- users ----------
    match /users/{userId} {
      // User can read their own doc; admin can read any
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      // Only backend (via Admin SDK) should write user docs.
      // Frontend registration goes through /api/auth/register, not direct Firestore writes.
      allow write: if false;
    }

    // ---------- inventory ----------
    match /inventory/{itemId} {
      // Any authenticated user can read inventory (students need real-time stock view)
      allow read: if isAuth();
      // Only admins can write inventory
      allow write: if isAdmin();
    }

    // ---------- reservations ----------
    match /reservations/{reservationId} {
      // Student can read their own; admin can read all
      allow read: if isAuth() && (isAdmin() || resource.data.studentId == request.auth.uid);
      // Students can create reservations; only backend handles updates (cancel/collect)
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ---------- pickupHistory ----------
    match /pickupHistory/{historyId} {
      // Student reads own history; admin reads all
      allow read: if isAuth() && (isAdmin() || resource.data.studentId == request.auth.uid);
      // Only backend writes pickup history (via Admin SDK)
      allow write: if false;
    }
  }
}
